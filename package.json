{
  "name": "beatmatcher",
  "version": "0.1.4",
  "description": "Beat matching trainer app",
  "main": "./out/main/index.js",
  "author": "berrutti",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit",
    "build:web": "vite build --config vite.web.config.ts",
    "dev:web": "vite --config vite.web.config.ts",
    "icon": "electron scripts/svg-to-png.js",
    "dist": "electron-vite build && electron-builder",
    "release": "tsx scripts/release.ts",
    "release:minor": "tsx scripts/release.ts minor",
    "release:major": "tsx scripts/release.ts major",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.berrutti.beatmatcher",
    "productName": "BeatMatcher",
    "icon": "build/icon",
    "files": [
      "out/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.music"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "pinia": "^2.3.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/vite": "^4.1.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.2",
    "vitest": "^3.2.1",
    "vue-tsc": "^2.2.8"
  }
}
